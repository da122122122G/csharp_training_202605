@using WebApp_training.Presentations.ViewModels
@model EmployeeDeleteViewModel;
@{
    ViewData["Title"] = "社員削除(完了)";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-sm-8 text-center">
            <div class="alert alert-success" role="alert">
                社員情報の削除が完了しました。
            </div>
            <table class="table">
                <tbody>
                    @*削除した社員と所属部署を表示する*@
                    <tr>
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.EmpId)</td>
                        <td>@Html.DisplayFor(m => m.EmpId)</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.EmpName)</td>
                        <td>@Html.DisplayFor(m => m.EmpName)</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.PhoneNum)</td>
                        <td>@Html.DisplayFor(m => m.PhoneNum)</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.EMail)</td>
                        <td>@Html.DisplayFor(m => m.EMail)</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.DeptName)</td>
                        <td>@Html.DisplayFor(m => m.DeptName)</td>
                    </tr>
                </tbody>
            </table>
            @*入力画面に戻る*@
            <a asp-action="Enter" asp-controller="EmployeeDelete" class="btn btn-primary mt-3">
                続けて削除する
            </a>
            @*メニューに戻る*@
            <a asp-action="Index" asp-controller="Home" class="btn btn-secondary mt-3 ms-2">
                メニューに戻る
            </a>
        </div>
    </div>
</div>