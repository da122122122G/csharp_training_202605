@using WebApp_training.Presentations.ViewModels
@model DepartmentDeleteViewModel;
@{
    ViewData["Title"] = "部署削除(完了)";
    var deletedDeptName = TempData["DeletedDeptName"] as string ?? ViewBag.DeletedDeptName as string;
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-sm-8 text-center">
            <div class="alert alert-success mt-4">
                @* 部署名がちゃんと引き継がれているかチェックして表示を変える *@
                @if (!string.IsNullOrEmpty(deletedDeptName))
                {
                    <p class="mb-0">@deletedDeptName の削除が完了しました。</p>
                }
                else
                {
                    <p class="mb-0">部署の削除が完了しました。</p>

                }
                @if (ViewBag.MovedEmployeeCount > 0)
                {
                <p class="mb-0">
                    所属していた @ViewBag.MovedEmployeeCount 名の社員の部署が「未所属」になりました。
                </p>
                }
            </div>
            @*入力画面に戻る*@
            <a asp-action="Enter" asp-controller="DepartmentDelete" class="btn btn-primary mt-3">
                続けて削除する
            </a>
            @*メニューに戻る*@
            <a asp-action="Index" asp-controller="Home" class="btn btn-secondary mt-3 ms-2">
                メニューに戻る
            </a>
        </div>
    </div>
</div>